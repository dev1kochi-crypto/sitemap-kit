{
    "name": "mightywarnerskochi/sitemap-kit",
    "description": "A reusable Laravel package for automatic sitemap generation.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/mightywarnerskochi/sitemap-kit",
    "authors": [
        {
            "name": "mightywarnerskochi",
            "email": "support@mightywarnerskochi.com"
        }
    ],
    "require": {
        "php": "^7.4|^8.0|^8.1",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0",
        "spatie/laravel-sitemap": "^5.8|^5.9|^6.0|^7.0"
    },
    "autoload": {
        "psr-4": {
            "MightyWarnersKochi\\SitemapKit\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MightyWarnersKochi\\SitemapKit\\SitemapAutomationServiceProvider"
            ]
        }
    }
}
